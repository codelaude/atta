    ],
    "tier_2_merge_required": [
      "agents/project-owner.md",
      "agents/librarian.md",
      "agents/code-reviewer.md",
      "agents/architect.md",
      "agents/rubber-duck.md",
      "agents/business-analyst.md",
      "agents/qa-validator.md",
      "agents/pr-manager.md"
    ],
    "tier_3_never_touch": [
      "agents/memory/**/*",
      "project/**/*",
      "local/accs/**/*",
      "agents-config.json",
      "settings.local.json",
      ".metadata/file-manifest.json",
      ".metadata/framework-version",
      ".metadata/update-history.json"
    ],
    "generated_optional": [
      "agents/coordinators/**/*",
      "agents/specialists/**/*",
      "team/patterns/**/*",
      "agents/INDEX.md",
      "skills/generated/**/*"
    ]
  },
  "notes": "This manifest tracks which files are framework vs user content. Updated by /atta, /atta-migrate, and /atta-update skills."
