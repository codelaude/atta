# Defense-in-depth: package.json "files" is the primary whitelist.
# This file catches anything that slips through.

# Development workspace
.claude_dev/
dev/

# Environment and local settings
.env*
.claude/settings.local.json

# Dev-only scripts
.atta/scripts/validate-framework.sh

# Generated runtime files (should not ship in npm package)
# Note: package.json "files" array takes precedence — template docs in
# local/context/ and local/sessions/ are still shipped. This catches
# any other local/ files that slip through (e.g. generated ACCs, PR docs).
.atta/local/

# GitHub community files (not needed in npm package)
.github/

# Build artifacts
*.tgz

# IDE and OS
.DS_Store
.vscode/
.idea/
